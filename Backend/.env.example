# MongoDB connection string — Atlas: project dashboard → connect → drivers
MONGO_URI=mongodb_connection_string

# Server port
PORT=5000

# JWT signing secret — generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=your_jwt_secret_here

# SMTP email settings (works with Gmail, Outlook, SendGrid SMTP relay, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Display name shown in the From field
EMAIL_FROM_NAME=EventHub

# Frontend base URL — used to build RSVP modify links in emails
FRONTEND_URL=http://localhost:5173