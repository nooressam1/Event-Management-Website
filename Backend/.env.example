# MongoDB connection string — Atlas: project dashboard → connect → drivers
MONGO_URI=mongodb_connection_string

# Server port
PORT=5000

# JWT signing secret — generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=your_jwt_secret_here

# Groq API key — get yours at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here